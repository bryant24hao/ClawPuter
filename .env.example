# ClawPuter — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then source before building:
#   source .env && pio run -t upload

# ── WiFi (required) ──
export WIFI_SSID="<your-wifi-ssid>"
export WIFI_PASS="<your-wifi-password>"

# ── AI Backend: OpenClaw Gateway (required for chat) ──
# See: https://github.com/anthropics/openclaw
export OPENCLAW_HOST="<your-host-ip>"         # LAN IP of machine running OpenClaw Gateway
export OPENCLAW_PORT="<your-port>"            # Gateway port (default: 18789)
export OPENCLAW_TOKEN="<your-gateway-token>"  # Gateway access token

# ── Voice Input (optional) ──
# Groq API key for Whisper STT, used by tools/stt_proxy.py
export GROQ_API_KEY="<your-groq-api-key>"
# Machine running stt_proxy.py (usually same as OPENCLAW_HOST)
export STT_PROXY_HOST="<your-host-ip>"
export STT_PROXY_PORT="8090"

# ── Secondary WiFi (optional, phone hotspot fallback) ──
export WIFI_SSID2="<your-hotspot-ssid>"
export WIFI_PASS2="<your-hotspot-password>"
export OPENCLAW_HOST2="<your-hotspot-host-ip>"

# ── Claude API (optional, unused in current firmware) ──
# export CLAUDE_API_KEY="<your-claude-api-key>"
